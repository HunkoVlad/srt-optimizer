# Virtual environment
.venv/

# Local configuration and secrets
.env
.env.*
!config/*.example.env

# Legacy top-level generated outputs
manifest.json
standardized/**
!standardized/
!standardized/.gitkeep
analysis/**
!analysis/
!analysis/.gitkeep

# Real run artifacts
data/runs/**
!data/
!data/runs/

# Logs
logs/**
!logs/
!logs/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Test cache
.pytest_cache/
